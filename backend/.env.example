# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL via Supabase ──────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<your-supabase-ref>.supabase.co:5432/postgres

# For local PostgreSQL (pgAdmin):
# DATABASE_URL=postgresql://postgres:<password>@localhost:5432/inventory_db

# ─── Python Analytics ─────────────────────────────────────────────────────────
PYTHON_ANALYTICS_URL=http://localhost:8000

# ─── Email Alerts (Gmail SMTP) ────────────────────────────────────────────────
# Gmail App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_app_password
OWNER_EMAIL=your@gmail.com

# ─── POS Billing ──────────────────────────────────────────────────────────────
SHOP_NAME=My Store
SHOP_CONTACT_EMAIL=contact@mystore.com
