generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vendor {
  id           Int         @id @default(autoincrement())
  name         String
  email        String      @unique
  phone        String?
  leadTimeDays Int         @default(7) @map("lead_time_days")
  createdAt    DateTime    @default(now()) @map("created_at")
  items        Inventory[]

  @@map("vendors")
}

model Inventory {
  id                Int           @id @default(autoincrement())
  itemName          String        @map("item_name")
  category          String?
  quantity          Int           @default(0)
  minQuantity       Int           @default(10) @map("min_quantity")
  unitPrice         Decimal?      @db.Decimal(10, 2) @map("unit_price")
  warehouseLocation String?       @map("warehouse_location")
  vendorId          Int?          @map("vendor_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  vendor            Vendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  transactions      Transaction[]
  alerts            Alert[]
  dailySales        DailySale[]
  billItems         BillItem[]

  @@index([vendorId])
  @@map("inventory")
}

model DailySale {
  id           Int       @id @default(autoincrement())
  inventoryId  Int       @map("inventory_id")
  saleDate     DateTime  @map("sale_date") @db.Date
  quantitySold Int       @default(0) @map("quantity_sold")
  inventory    Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@map("daily_sales")
}

model Transaction {
  id          Int       @id @default(autoincrement())
  inventoryId Int       @map("inventory_id")
  type        String
  quantity    Int
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Alert {
  id          Int       @id @default(autoincrement())
  inventoryId Int       @map("inventory_id")
  alertType   String    @map("alert_type")
  message     String
  resolved    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

model User {
  id                Int                @id @default(autoincrement())
  fullName          String             @map("full_name")
  email             String             @unique
  passwordHash      String             @map("password_hash")
  role              String             @default("employee")  // "admin" | "employee"
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  lastLogin         DateTime?          @map("last_login")
  approvedVendors   VendorAccount[]    @relation("ApprovedBy")
  reviewedOffers    VendorStockOffer[] @relation("ReviewedBy")
  auditLogs         AuditLog[]

  @@map("users")
}

model VendorAccount {
  id            Int                @id @default(autoincrement())
  companyName   String             @map("company_name")
  contactName   String             @map("contact_name")
  email         String             @unique
  passwordHash  String             @map("password_hash")
  phone         String?
  isActive      Boolean            @default(false) @map("is_active")
  approvedById  Int?               @map("approved_by_id")
  approvedAt    DateTime?          @map("approved_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  approvedBy    User?              @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  offers        VendorStockOffer[]

  @@map("vendor_accounts")
}

model VendorStockOffer {
  id              Int            @id @default(autoincrement())
  vendorAccountId Int            @map("vendor_account_id")
  itemName        String         @map("item_name")
  category        String?
  unitPrice       Decimal        @db.Decimal(10, 2) @map("unit_price")
  minOrderQty     Int            @map("min_order_qty")
  leadTimeDays    Int            @map("lead_time_days")
  notes           String?
  status          String         @default("pending")  // "pending" | "accepted" | "rejected"
  adminNotes      String?        @map("admin_notes")
  reviewedById    Int?           @map("reviewed_by_id")
  reviewedAt      DateTime?      @map("reviewed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  vendorAccount   VendorAccount  @relation(fields: [vendorAccountId], references: [id], onDelete: Cascade)
  reviewedBy      User?          @relation("ReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([vendorAccountId])
  @@map("vendor_stock_offers")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String
  performedBy Int      @map("performed_by")
  targetId    Int      @map("target_id")
  details     String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [performedBy], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model Bill {
  id            Int        @id @default(autoincrement())
  billNumber    String     @unique @map("bill_number")        // e.g. BILL-0001
  customerEmail String     @map("customer_email")
  customerName  String?    @map("customer_name")
  total         Decimal    @db.Decimal(10, 2)
  status        String     @default("paid")                  // "paid" | "cancelled"
  createdAt     DateTime   @default(now()) @map("created_at")
  items         BillItem[]

  @@map("bills")
}

model BillItem {
  id            Int        @id @default(autoincrement())
  billId        Int        @map("bill_id")
  inventoryId   Int?       @map("inventory_id")              // nullable: item may be deleted later
  itemName      String     @map("item_name")                 // snapshot at time of sale
  unitPrice     Decimal    @db.Decimal(10, 2) @map("unit_price") // snapshot at time of sale
  quantity      Int
  subtotal      Decimal    @db.Decimal(10, 2)
  bill          Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  inventory     Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([inventoryId])
  @@map("bill_items")
}

